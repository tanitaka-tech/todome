{
  "name": "todome-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch server/index.ts",
    "start": "bun server/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:client": "npm --prefix client exec -- tsc -b",
    "lint": "npm --prefix client run lint",
    "test": "bun test server",
    "check": "bun run typecheck && bun run typecheck:client && bun run lint && bun run test"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.119",
    "hono": "^4.6.0",
    "ical.js": "^2.2.1",
    "tsdav": "^2.1.8"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "typescript": "^6.0.3"
  }
}
