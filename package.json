{
  "name": "todome-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch server/index.ts",
    "start": "bun server/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test server",
    "check": "bun run typecheck && cd client && npx tsc -b && npm run lint && cd .. && bun run test"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.119",
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "typescript": "^5.9.0"
  }
}
