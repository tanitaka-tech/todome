# Python
__pycache__/
*.pyc
*.pyo
.venv/

# Env
.env
.env.*
!.env.example

# Local data (DB / 各種 config JSON / GitHub 同期 repo)。
# 認証情報を含み得るので data/ 配下は原則すべて ignore する。
# ディレクトリの存在維持には data/.gitkeep を例外的に追跡する。
data/*
!data/.gitkeep

# Node / Vite
node_modules/
client/node_modules/
client/dist/
client/.vite/

# OS
.DS_Store

# IDE / editor local settings
.idea/
.claude/settings.local.json

# Playwright E2E
e2e/node_modules/
e2e/data-e2e/
e2e/data-manual/
e2e/test-results/
e2e/playwright-report/
e2e/playwright/.cache/
e2e/animation-frames/

# Playwright が project root から起動された場合の出力先
test-results/
playwright-report/
